# Aura 環境變數範本
# 使用方式：複製為 .env 後填入實際值
# .env 已在 .gitignore，不會被 commit

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
# 產生新 SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=please-generate-a-new-secret-key

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Production 才開啟
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_NAME=aura_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# 開發階段可設 True 讓 celery task 同步執行（不需要 worker）
CELERY_TASK_ALWAYS_EAGER=False

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Aura ERP <noreply@aura-erp.com>

# 正式環境（Railway）：SMTP 被封鎖，改走 Resend HTTPS API。
# 將 EMAIL_BACKEND 設為下行、填入 RESEND_API_KEY，並確保 EMAIL_HOST 留空。
# EMAIL_BACKEND=anymail.backends.resend.EmailBackend
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Wagtail / Misc
# -----------------------------------------------------------------------------
WAGTAILADMIN_BASE_URL=http://localhost:8000
LINE_OA_URL=https://lin.ee/RYzygHv
# 官網諮詢通知收件信箱 fallback（主要改在 admin 系統參數設定 INQUIRY_NOTIFY_EMAIL；留空不寄）
INQUIRY_NOTIFY_EMAIL=

# Windows 本機開發使用 npm.cmd，Docker 環境改 npm
NPM_BIN_PATH=npm.cmd

# 日誌等級：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Sentry（可選 — 註冊 https://sentry.io 後填入 DSN）
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
